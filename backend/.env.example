# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Node Monitor
APP_SHORT_NAME=Nodes

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
DOMAIN_NAME=your-domain.com

# ─── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars

# ─── Local Node ────────────────────────────────────────────────────────────────
# Which node is this backend physically running ON?
# Commands for that node run via local child_process (no SSH, no extra user needed).
#   node2  →  backend running on the second node
#   node1  →  backend running on the first node
#   none   →  backend on a separate VM (SSH into both nodes)
NODE_LOCAL_ID=node2

# ─── SSH Configuration ─────────────────────────────────────────────────────────
# The 'monitor' user must have passwordless sudo for specific commands, or use a
# dedicated service account with read permissions on /proc, nvidia-smi, sensors
SSH_USER=monitor

# Option A: SSH key authentication (recommended)
SSH_KEY_PATH=/home/monitor/.ssh/id_ed25519

# Option B: Password authentication (less secure)
# NODE1_SSH_PASS=your-password
# NODE2_SSH_PASS=your-password

# Node hostnames and labels
NODE1_HOST=node1.example.com
NODE1_LABEL=node-1
NODE1_SSH_PORT=22

NODE2_HOST=node2.example.com
NODE2_LABEL=node-2
NODE2_SSH_PORT=22

# ─── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/node-monitor.db

# ─── Thresholds (optional overrides) ──────────────────────────────────────────
GPU_TEMP_CRITICAL=85
RAM_CRITICAL_PCT=95