# ============================================================================
# Node Monitor — Nginx Configuration Example
# ============================================================================
#
# This is an EXAMPLE configuration file. Copy this to nginx.conf and update
# all placeholders marked with CHANGE_THIS before deploying.
#
# Quick Start:
#   1. Copy this file: cp nginx.conf.example nginx.conf
#   2. Replace all CHANGE_THIS placeholders with your actual values
#   3. sudo cp nginx.conf /etc/nginx/sites-available/node-monitor
#   4. sudo ln -s /etc/nginx/sites-available/node-monitor /etc/nginx/sites-enabled/
#   5. sudo certbot --nginx -d your-domain.com (for SSL)
#   6. sudo nginx -t && sudo systemctl reload nginx
#
# ============================================================================

# ─── Rate Limiting Zones ────────────────────────────────────────────────────
# Protects against brute-force login attempts and API abuse
limit_req_zone $binary_remote_addr zone=login:10m rate=10r/m;  # 10 logins per minute
limit_req_zone $binary_remote_addr zone=api:10m    rate=60r/s; # 60 API requests per second

# ─── Upstream Backend ───────────────────────────────────────────────────────
# Points to your Node.js backend service
upstream node_monitor_backend {
    server 127.0.0.1:3001;  # CHANGE_THIS if backend runs on different port
    keepalive 32;           # Keep connections alive for better performance
}

# ─── HTTP → HTTPS Redirect ──────────────────────────────────────────────────
# Redirects all HTTP traffic to HTTPS (remove if not using SSL)
server {
    listen 80;
    listen [::]:80;
    server_name CHANGE_THIS_your-domain.com;  # CHANGE_THIS to your actual domain

    # Let's Encrypt challenge directory (for certbot)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Redirect everything else to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# ─── HTTPS Server ───────────────────────────────────────────────────────────
server {
    # SSL configuration (Nginx 1.25+: use 'http2 on;' directive instead)
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name CHANGE_THIS_your-domain.com;  # CHANGE_THIS to your actual domain

    # ── SSL Certificates ─────────────────────────────────────────────────────
    # CHANGE_THIS to your actual certificate paths (certbot will update these)
    ssl_certificate     /etc/letsencrypt/live/CHANGE_THIS_your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/CHANGE_THIS_your-domain.com/privkey.pem;

    # Include certbot's SSL configuration (optional but recommended)
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # ── Security Headers ─────────────────────────────────────────────────────
    # Protects against common web vulnerabilities
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' wss://$host ws://$host; img-src 'self' data:;" always;

    # ── Logging ──────────────────────────────────────────────────────────────
    access_log /var/log/nginx/node-monitor.access.log;
    error_log  /var/log/nginx/node-monitor.error.log warn;

    # ── Gzip Compression ─────────────────────────────────────────────────────
    # Reduces bandwidth usage
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_min_length 1024;
    gzip_comp_level 5;

    # ── Frontend Static Files ────────────────────────────────────────────────
    # CHANGE_THIS to your actual deployment path
    root /CHANGE_THIS/path/to/node-monitor/frontend/dist;
    index index.html;

    location / {
        # Try to serve static files, fallback to index.html for SPA routing
        try_files $uri $uri/ /index.html;

        # Cache hashed Vite assets aggressively (they have content hashes in filenames)
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2|woff|ttf)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # ── Authentication API ───────────────────────────────────────────────────
    # Strict rate limit to prevent brute-force attacks
    location /api/auth/login {
        limit_req zone=login burst=5 nodelay;
        limit_req_status 429;

        proxy_pass         http://node_monitor_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # ── Terminal WebSocket ───────────────────────────────────────────────────
    # Long-lived WebSocket connection for xterm.js terminal
    location /api/terminal/attach {
        proxy_pass         http://node_monitor_backend;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Keep terminal connections alive
        proxy_read_timeout 3600s;  # 1 hour
        proxy_send_timeout 3600s;
    }

    # ── Metrics WebSocket ────────────────────────────────────────────────────
    # Real-time metrics updates via WebSocket
    location /ws/ {
        proxy_pass         http://node_monitor_backend;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Keep WebSocket alive for 24 hours
        proxy_read_timeout 86400s;
    }

    # ── General API Endpoints ────────────────────────────────────────────────
    # All other API routes
    location /api/ {
        limit_req zone=api burst=20 nodelay;

        proxy_pass         http://node_monitor_backend;
        proxy_http_version 1.1;
        proxy_set_header   Connection        "";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Reasonable timeouts for API calls
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # ── Block Hidden Files ───────────────────────────────────────────────────
    # Prevent access to .git, .env, etc.
    location ~ /\. {
        deny all;
        return 404;
    }
}

# ============================================================================
# CONFIGURATION CHECKLIST
# ============================================================================
#
# Before deploying, ensure you have changed:
#
# [ ] Line 27:  server_name CHANGE_THIS_your-domain.com
# [ ] Line 43:  server_name CHANGE_THIS_your-domain.com
# [ ] Line 47:  ssl_certificate path
# [ ] Line 48:  ssl_certificate_key path
# [ ] Line 67:  root /CHANGE_THIS/path/to/node-monitor/frontend/dist
# [ ] Line 16:  upstream backend port (if not 3001)
#
# Optional changes based on your setup:
#
# [ ] Adjust rate limits (lines 13-14) for your needs
# [ ] Update log paths (lines 62-63) if desired
# [ ] Modify security headers (lines 55-60) as needed
# [ ] Adjust timeout values if needed
#
# After configuration:
#   sudo nginx -t              # Test configuration
#   sudo systemctl reload nginx # Apply changes
#
# ============================================================================
